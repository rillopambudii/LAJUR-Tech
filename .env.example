APP_NAME=Laravel
# PRODUKSI: APP_ENV=production, APP_DEBUG=false. Kalau APP_DEBUG=true di server,
# halaman error membocorkan stack trace BESERTA isi berkas ini ke pengunjung.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# PRODUKSI: isi domain asli (https://...). Dipakai untuk tautan reset password,
# URL gambar, dan subdomain tenant.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# PRODUKSI: WAJIB smtp + kredensial. Selama 'log', email hanya masuk berkas log —
# tautan lupa-password tak pernah sampai ke owner, invoice tak sampai ke pelanggan.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# AI business assistant. Provider: 'anthropic' or 'openai' (OpenAI-compatible: Groq/Ollama/OpenRouter).
AI_PROVIDER=anthropic

# Anthropic (Claude) driver.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# OpenAI-compatible driver. For Groq (free): AI_PROVIDER=openai + a gsk_... key below.
# Ollama (local): OPENAI_BASE_URL=http://localhost:11434/v1, OPENAI_API_KEY=ollama, OPENAI_MODEL=qwen2.5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Unit tracking (GPS). Google Maps key for /admin/tracking. TRACKING_DEMO=true shows
# simulated positions before the Traccar integration is wired up.
GOOGLE_MAPS_API_KEY=
TRACKING_DEMO=false

# CA bundle for outbound HTTPS. Set on local dev if you hit "cURL error 60"
# (e.g. C:/laragon/etc/ssl/cacert.pem). Leave blank in production.
CURL_CA_BUNDLE=

# Payment gateway. PAYMENT_GATEWAY=manual (default, offline) or midtrans.
PAYMENT_GATEWAY=manual
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
# Mode dan kunci HARUS dari lingkungan yang sama. Kunci sandbox berawalan 'SB-'.
# Campur (mis. kunci produksi + mode sandbox) = Midtrans menolak, pelanggan gagal bayar.
# Periksa dengan: php artisan lajur:preflight
MIDTRANS_IS_PRODUCTION=false

VITE_APP_NAME="${APP_NAME}"
